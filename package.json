{
  "name": "indie-suite",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:marketing": "npm run dev -w marketing",
    "dev:app": "npm run dev -w app",
    "build:marketing": "npm run build -w marketing",
    "build:app": "npm run build -w app",
    "build": "npm run build:marketing && npm run build:app",
    "lint:marketing": "npm run lint -w marketing",
    "lint:app": "npm run lint -w app",
    "lint": "npm run lint:marketing && npm run lint:app",
    "test:app": "npm run test -w app",
    "test": "npm run test:app"
  },
  "packageManager": "npm@11.6.2"
}
